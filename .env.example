# =============================================================================
# OCEANX ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and .env.local (for Next.js)
# ⚠️ NEVER commit .env or .env.local to git - they contain secrets!
# =============================================================================

# -----------------------------------------------------------------------------
# FRONTEND CONFIGURATION (NEXT_PUBLIC_* = exposed to browser)
# -----------------------------------------------------------------------------

# Site URL (your deployed frontend URL)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (safe to expose - anon key only)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Backend API URLs
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_WS_URL=ws://localhost:5000

# Smart Contract Addresses (on your target network)
NEXT_PUBLIC_OCEAN_X_TOKEN_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_PLAYER_PROFILE_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_UPGRADE_MANAGER_ADDRESS=0x1234567890123456789012345678901234567890

# WalletConnect (for mobile wallet support on BASE blockchain)
# Get your Project ID from https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# BASE Blockchain Configuration
# Set to 'true' for Base Mainnet, 'false' or omit for Base Sepolia (testnet)
NEXT_PUBLIC_USE_BASE_MAINNET=false

# Leaderboard explorer source (default: Sepolia Etherscan)
# Options: sepolia-etherscan | basescan-sepolia | basescan-mainnet
LEADERBOARD_EXPLORER_MODE=sepolia-etherscan

# Optional override for OCX token used by leaderboard explorer queries
# If omitted, falls back to NEXT_PUBLIC_OCEAN_X_TOKEN_ADDRESS / NEXT_PUBLIC_TOKEN_CONTRACT_ADDRESS
# LEADERBOARD_OCX_TOKEN_ADDRESS=0x1234567890123456789012345678901234567890

# Optional tuning for explorer-backed leaderboard
# LEADERBOARD_SCAN_PAGE_SIZE=100
# LEADERBOARD_SCAN_MAX_PAGES=3
# LEADERBOARD_OCX_DECIMALS=18
# LEADERBOARD_CACHE_TTL_MS=60000

# Leaderboard transaction source filtering (recommended)
# Only transfers sent from these addresses are counted as earned OCX.
# Comma-separated list of payout wallet/contract addresses.
# Example:
# LEADERBOARD_ALLOWED_SOURCE_ADDRESSES=0x1111111111111111111111111111111111111111,0x2222222222222222222222222222222222222222
LEADERBOARD_ALLOWED_SOURCE_ADDRESSES=

# Set to false only if you explicitly want to count all incoming OCX transfers.
LEADERBOARD_ENFORCE_SOURCE_FILTER=true

# Explorer API keys (recommended to avoid rate limits)
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=

# Base RPC URLs (optional - defaults provided)
# NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
# NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional: Testing mode (DO NOT USE IN PRODUCTION)
# NEXT_PUBLIC_ALLOW_BLOCKCHAIN_BYPASS=false

# -----------------------------------------------------------------------------
# BACKEND CONFIGURATION (server/.env - KEEP SECRET!)
# -----------------------------------------------------------------------------

# Blockchain
RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY_HERE
CHAIN_ID=11155111
TOKEN_CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE

# ⚠️ CRITICAL: Backend signer private key
# This wallet signs claim authorizations (does NOT pay gas)
# Generate new key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BACKEND_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Database (Supabase)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Signature expiry (optional)
JOIN_SIGNATURE_MAX_AGE_MS=300000
AUTH_SIGNATURE_MAX_AGE_MS=300000
CLAIM_SIGNATURE_EXPIRY_SEC=300

# =============================================================================
# SECURITY CHECKLIST
# =============================================================================
# ✅ .env and .env.local are in .gitignore
# ✅ BACKEND_PRIVATE_KEY is unique (never reuse test keys)
# ✅ Backend wallet has minimal ETH (for RPC calls only)
# ✅ SUPABASE_SERVICE_ROLE_KEY is never exposed to frontend
# ✅ NODE_ENV=production on deployed servers
# ✅ All NEXT_PUBLIC_* values are safe to expose
# =============================================================================